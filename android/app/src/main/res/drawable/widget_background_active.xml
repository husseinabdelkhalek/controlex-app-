<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border Gradient (Cyan to Violet) representing glowing active state -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00E5FF"
                android:endColor="#8A2BE2"
                android:angle="45" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Background Card Content (inset by 2dp) -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#F90D0C1D" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
