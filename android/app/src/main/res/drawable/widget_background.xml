<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border Gradient (Cyan to Violet) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00E5FF"
                android:endColor="#8A2BE2"
                android:angle="45" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Background Card Content (solid deep dark, inset by 1.5dp) -->
    <item android:left="1.5dp" android:top="1.5dp" android:right="1.5dp" android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#F90D0C1D" /> <!-- Solid dark background matching AppTheme -->
            <corners android:radius="22.5dp" />
        </shape>
    </item>
</layer-list>
