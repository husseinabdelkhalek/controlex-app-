<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Track -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" /> <!-- Semi-transparent grey track for OFF state -->
            <corners android:radius="15dp" />
            <size android:width="50dp" android:height="30dp" />
        </shape>
    </item>
    <!-- Thumb (shifted left) -->
    <item android:left="2dp" android:top="2dp" android:right="22dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#B0B0B0" />
        </shape>
    </item>
</layer-list>
