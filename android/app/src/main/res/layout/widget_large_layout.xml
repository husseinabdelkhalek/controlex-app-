<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <!-- Icon Container -->
        <FrameLayout
            android:id="@+id/icon_container"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_bg">
            
            <ImageView
                android:id="@+id/widget_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_setup" />
        </FrameLayout>

        <!-- Device/Tool Name and Type -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/icon_container"
            android:layout_toStartOf="@id/widget_refresh_button"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ControlEx"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup Required"
                android:textColor="#8A2BE2"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Refresh / Trigger Button -->
        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_bg"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- Divider Line -->
    <ImageView
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/header_container"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF" />

    <!-- Content Containers (toggled in Kotlin code) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:layout_marginTop="8dp">

        <!-- 1. Setup/Unconfigured Layout -->
        <LinearLayout
            android:id="@+id/layout_setup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to setup large widget"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 2. Terminal Layout -->
        <RelativeLayout
            android:id="@+id/layout_terminal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Monospace logs container -->
            <LinearLayout
                android:id="@+id/terminal_console_box"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@id/terminal_actions_container"
                android:layout_marginBottom="6dp"
                android:background="#E6000000"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- macOS-like buttons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#FF5F56" android:layout_marginEnd="3dp"/>
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#FFBD2E" android:layout_marginEnd="3dp"/>
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#27C93F"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_terminal_logs"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="guest@controlex:~$\n> waiting for logs..."
                    android:textColor="#00FF00"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Bottom Interactive Commands Row -->
            <LinearLayout
                android:id="@+id/terminal_actions_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btn_cmd_status"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:gravity="center"
                    android:text="status"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_cmd_ping"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:gravity="center"
                    android:text="ping"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_cmd_clear"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:gravity="center"
                    android:text="clear"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <!-- Open Keyboard in App button -->
                <ImageView
                    android:id="@+id/btn_cmd_keyboard"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/widget_icon_bg"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="#FFFFFF" />

            </LinearLayout>

        </RelativeLayout>

        <!-- 3. Joystick Layout -->
        <RelativeLayout
            android:id="@+id/layout_joystick"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_centerInParent="true"
                android:background="@drawable/widget_joystick_base"
                android:padding="8dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:columnCount="3"
                    android:rowCount="3">

                    <!-- Row 1 -->
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:visibility="invisible" />
                    
                    <ImageView
                        android:id="@+id/btn_joy_up"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/widget_icon_bg"
                        android:padding="10dp"
                        android:src="@drawable/ic_widget_arrow"
                        android:rotation="0"
                        android:tint="#00E5FF" />
                        
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:visibility="invisible" />

                    <!-- Row 2 -->
                    <ImageView
                        android:id="@+id/btn_joy_left"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/widget_icon_bg"
                        android:padding="10dp"
                        android:src="@drawable/ic_widget_arrow"
                        android:rotation="270"
                        android:tint="#00E5FF" />

                    <ImageView
                        android:id="@+id/btn_joy_center"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/widget_joystick_stick"
                        android:padding="12dp"
                        android:src="@android:drawable/presence_online"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:id="@+id/btn_joy_right"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/widget_icon_bg"
                        android:padding="10dp"
                        android:src="@drawable/ic_widget_arrow"
                        android:rotation="90"
                        android:tint="#00E5FF" />

                    <!-- Row 3 -->
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:visibility="invisible" />

                    <ImageView
                        android:id="@+id/btn_joy_down"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/widget_icon_bg"
                        android:padding="10dp"
                        android:src="@drawable/ic_widget_arrow"
                        android:rotation="180"
                        android:tint="#00E5FF" />

                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:visibility="invisible" />

                </GridLayout>
            </RelativeLayout>
        </RelativeLayout>

        <!-- 4. Toggle Layout -->
        <RelativeLayout
            android:id="@+id/layout_toggle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_toggle_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:text="OFF"
                android:textColor="#B3FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/widget_toggle_switch_img"
                android:layout_width="60dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:src="@drawable/widget_switch_off" />
        </RelativeLayout>

        <!-- 5. Push Layout -->
        <LinearLayout
            android:id="@+id/layout_push"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            android:background="@drawable/widget_icon_bg"
            android:padding="12dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_widget_push"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btn_push_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIGGER PUSH"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 6. Sensor Layout -->
        <LinearLayout
            android:id="@+id/layout_sensor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_sensor_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24"
                android:textColor="#00E5FF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_sensor_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="°C"
                android:textColor="#B3FFFFFF"
                android:textSize="20sp" />
        </LinearLayout>

        <!-- 7. Slider Layout -->
        <LinearLayout
            android:id="@+id/layout_slider"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btn_slider_minus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="10dp"
                android:src="@drawable/ic_widget_minus"
                android:tint="#00E5FF" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_slider_value_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <ProgressBar
                    android:id="@+id/widget_slider_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="6dp"
                    android:progress="0"
                    android:max="100"
                    android:progressTint="#00E5FF"
                    android:progressBackgroundTint="#33FFFFFF"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/btn_slider_plus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/widget_icon_bg"
                android:padding="10dp"
                android:src="@drawable/ic_widget_plus"
                android:tint="#00E5FF" />
        </LinearLayout>

        <!-- 8. ColorPicker Layout -->
        <LinearLayout
            android:id="@+id/layout_colorpicker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btn_color_red"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="8dp"
                android:background="@drawable/widget_icon_bg"
                android:backgroundTint="#FF5F56" />

            <ImageView
                android:id="@+id/btn_color_green"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="8dp"
                android:background="@drawable/widget_icon_bg"
                android:backgroundTint="#27C93F" />

            <ImageView
                android:id="@+id/btn_color_blue"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="8dp"
                android:background="@drawable/widget_icon_bg"
                android:backgroundTint="#2979FF" />

            <ImageView
                android:id="@+id/btn_color_purple"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="8dp"
                android:background="@drawable/widget_icon_bg"
                android:backgroundTint="#AA00FF" />
        </LinearLayout>

    </FrameLayout>

</RelativeLayout>
