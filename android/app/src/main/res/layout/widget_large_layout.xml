<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header Section -->
    <RelativeLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <!-- Icon Container -->
        <FrameLayout
            android:id="@+id/icon_container"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_bg">
            
            <ImageView
                android:id="@+id/widget_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_setup" />
        </FrameLayout>

        <!-- Device/Tool Name and Type -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/icon_container"
            android:layout_toStartOf="@id/widget_refresh_button"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ControlEx"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup Required"
                android:textColor="#8A2BE2"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Refresh / Trigger Button -->
        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_bg"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- Divider Line -->
    <ImageView
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/header_container"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF" />

    <!-- Content Containers (toggled in Kotlin code) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:layout_marginTop="8dp">

        <!-- 1. Setup/Unconfigured Layout -->
        <LinearLayout
            android:id="@+id/layout_setup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/widget_setup_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to setup"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- 2. Toggle Layout -->
        <RelativeLayout
            android:id="@+id/layout_toggle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Normal Toggle -->
            <RelativeLayout
                android:id="@+id/layout_toggle_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">
                <TextView
                    android:id="@+id/widget_toggle_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:text="OFF"
                    android:textColor="#B3FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/widget_toggle_switch_img"
                    android:layout_width="50dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/widget_switch_off" />
            </RelativeLayout>

            <!-- Compact Toggle (1x1) -->
            <FrameLayout
                android:id="@+id/layout_toggle_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/widget_toggle_switch_img_compact"
                    android:layout_width="50dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/widget_switch_off" />
            </FrameLayout>
        </RelativeLayout>

        <!-- 3. Push Layout -->
        <RelativeLayout
            android:id="@+id/layout_push"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Normal Push/Scene Button -->
            <LinearLayout
                android:id="@+id/layout_push_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/widget_icon_bg"
                android:padding="8dp"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/btn_push_icon_normal"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_widget_push"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/btn_push_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRIGGER PUSH"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Compact Push/Scene Button -->
            <FrameLayout
                android:id="@+id/layout_push_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_icon_bg"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/btn_push_icon_compact"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_push" />
            </FrameLayout>
        </RelativeLayout>

        <!-- 4. Sensor Layout -->
        <LinearLayout
            android:id="@+id/layout_sensor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_sensor_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24"
                android:textColor="#00E5FF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_sensor_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="°C"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 5. Terminal Layout -->
        <RelativeLayout
            android:id="@+id/layout_terminal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Normal Terminal Box -->
            <LinearLayout
                android:id="@+id/layout_terminal_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#D9000000"
                android:orientation="vertical"
                android:padding="6dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#FF5F56" android:layout_marginEnd="3dp"/>
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#FFBD2E" android:layout_marginEnd="3dp"/>
                    <ImageView android:layout_width="5dp" android:layout_height="5dp" android:background="#27C93F"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_terminal_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="guest@controlex:~$\n> command sent"
                    android:textColor="#00FF00"
                    android:textSize="9sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Compact Terminal Icon -->
            <FrameLayout
                android:id="@+id/layout_terminal_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_icon_bg"
                android:visibility="gone">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_widget_terminal" />
            </FrameLayout>
        </RelativeLayout>

        <!-- 6. Slider Layout -->
        <RelativeLayout
            android:id="@+id/layout_slider"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Normal Horizontal Slider -->
            <LinearLayout
                android:id="@+id/layout_slider_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/btn_slider_minus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/widget_icon_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_widget_minus"
                    android:tint="#00E5FF" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_slider_value_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="0%"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <ProgressBar
                        android:id="@+id/widget_slider_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="4dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="#00E5FF"
                        android:progressBackgroundTint="#33FFFFFF"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_slider_plus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/widget_icon_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_widget_plus"
                    android:tint="#00E5FF" />
            </LinearLayout>

            <!-- Compact Vertical Slider Stack (1x1) -->
            <LinearLayout
                android:id="@+id/layout_slider_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/btn_slider_plus_compact"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/widget_icon_bg"
                    android:padding="6dp"
                    android:src="@drawable/ic_widget_plus"
                    android:tint="#00E5FF" />

                <TextView
                    android:id="@+id/widget_slider_value_text_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:text="0%"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:id="@+id/btn_slider_minus_compact"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/widget_icon_bg"
                    android:padding="6dp"
                    android:src="@drawable/ic_widget_minus"
                    android:tint="#00E5FF" />
            </LinearLayout>
        </RelativeLayout>

        <!-- 7. ColorPicker Layout -->
        <RelativeLayout
            android:id="@+id/layout_colorpicker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Normal Horizontal Swatches -->
            <LinearLayout
                android:id="@+id/layout_colorpicker_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="visible">

                <ImageView
                    android:id="@+id/btn_color_red"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#FF5F56" />

                <ImageView
                    android:id="@+id/btn_color_green"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#27C93F" />

                <ImageView
                    android:id="@+id/btn_color_blue"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#2979FF" />

                <ImageView
                    android:id="@+id/btn_color_purple"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#AA00FF" />
            </LinearLayout>

            <!-- Compact 2x2 Grid Swatches (1x1) -->
            <GridLayout
                android:id="@+id/layout_colorpicker_compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:columnCount="2"
                android:rowCount="2"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/btn_color_red_compact"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#FF5F56" />

                <ImageView
                    android:id="@+id/btn_color_green_compact"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#27C93F" />

                <ImageView
                    android:id="@+id/btn_color_blue_compact"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#2979FF" />

                <ImageView
                    android:id="@+id/btn_color_purple_compact"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_margin="2dp"
                    android:background="@drawable/widget_icon_bg"
                    android:backgroundTint="#AA00FF" />
            </GridLayout>
        </RelativeLayout>

        <!-- 8. Chart Layout -->
        <RelativeLayout
            android:id="@+id/layout_chart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Chart Layout with live graph wave -->
            <LinearLayout
                android:id="@+id/layout_chart_normal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_widget_chart"
                        android:tint="#00E5FF"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/widget_chart_value_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="N/A"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Graph"
                        android:textColor="#00E5FF"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/widget_chart_graph_image"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:scaleType="fitXY" />
            </LinearLayout>

            <!-- Compact (1x1) Chart Layout (unused in large but kept) -->
            <FrameLayout
                android:id="@+id/layout_chart_compact"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <TextView
                    android:id="@+id/widget_chart_value_text_compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="N/A"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </FrameLayout>
        </RelativeLayout>

    </FrameLayout>

</RelativeLayout>
